<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App identity. The on-device launcher label stays in English in
         every locale because it is a brand identifier. -->
    <string name="app_name" translatable="false">Last Tile</string>

    <!-- Header / branding. The wordmark is intentionally untranslated. -->
    <string name="title_wordmark" translatable="false">LAST  TILE</string>
    <string name="tagline">merge · split · expand</string>

    <!-- Stat cards. -->
    <string name="stat_score">SCORE</string>
    <string name="stat_turn">TURN</string>
    <string name="stat_combo">COMBO</string>
    <string name="stat_shield">SHIELD</string>

    <!-- Shield system. -->
    <string name="shield_dialog_title">Earn shields</string>
    <string name="shield_dialog_body">Watch a short video to earn 3 shields. Use them to cleanse Fire, Ice or Poison tiles.</string>
    <string name="shield_dialog_watch">Watch</string>
    <string name="shield_dialog_cancel">Not now</string>
    <string name="shield_ad_unavailable">Ad isn\'t available right now. Please try again later.</string>
    <string name="shield_ad_loading">Loading ad…</string>
    <string name="shield_ad_skipped">Watch the full video to earn shields.</string>
    <string name="shield_ad_rewarded">3 shields added.</string>

    <!-- Primary buttons. -->
    <string name="btn_play_again">Play Again</string>
    <string name="btn_restart">Restart</string>
    <string name="btn_leaderboard">Leaderboard</string>
    <string name="btn_close">Close</string>
    <string name="btn_clear">Clear</string>

    <!-- Leaderboard dialog. -->
    <string name="leaderboard_title">LEADERBOARD</string>
    <string name="leaderboard_tab_global">Global</string>
    <string name="leaderboard_tab_local">Local</string>
    <string name="leaderboard_local_subtitle">Top 10 · local device</string>
    <string name="leaderboard_empty">No runs yet. Survive one full run to chart.</string>
    <string name="leaderboard_powered_by">Global rankings</string>

    <!-- Global tab states (in-app fetched leaderboard). -->
    <string name="leaderboard_load_failed">Couldn\'t load global scores.</string>
    <string name="leaderboard_empty_global">No scores yet. Play a round to be the first.</string>
    <string name="leaderboard_retry">Retry</string>
    <string name="leaderboard_loading">Loading…</string>

    <!-- v0.2.0: Firebase leaderboard pinning + cache refresh UI -->
    <string name="leaderboard_updated_ago">Updated %1$d min ago</string>
    <string name="leaderboard_refresh">Refresh</string>

    <!-- Status line. -->
    <string name="status_game_over">GAME  OVER</string>
    <string name="status_split">Split into halves.</string>
    <string name="status_frame_opened">Frame opened!</string>
    <string name="status_hint_match_or_split">Tap match · double-tap to split</string>
    <string name="status_hint_match">Tap an adjacent match</string>

    <!-- Hazard subtitles, %1$d is the remaining turns until the hazard's
         scheduled cleanse / jump / poison tick. Translators may shorten the
         labels but should keep the trailing "t" (turns) compact since the
         tile is small. -->
    <string name="hazard_fire_subtitle">FIRE %1$dt</string>
    <string name="hazard_ice_subtitle">ICE %1$dt</string>
    <string name="hazard_poison_subtitle">POIS %1$dt</string>

    <!-- Plural-aware cleanse banner. -->
    <plurals name="cleansed_hazards">
        <item quantity="one">Cleansed %d hazard!</item>
        <item quantity="other">Cleansed %d hazards!</item>
    </plurals>

    <!-- Leaderboard row formatting. The rank prefix uses "#" which reads
         the same in most scripts. The entry meta line abbreviates the run
         length (turns) and reports the board size as N×N. -->
    <string name="leaderboard_rank_format">#%1$d</string>
    <string name="leaderboard_entry_meta">t%1$d · %2$d×%2$d</string>

    <!-- Universal symbols rendered as text. translatable="false" because
         a "+" sign, the em-dash "—", and the lock emoji read identically
         in every locale; localising them risks degrading the visual icon. -->
    <string name="shield_drag_overlay_icon" translatable="false">+</string>
    <string name="tile_locked_icon" translatable="false">🔒</string>
    <string name="combo_inactive" translatable="false">—</string>

    <!-- Combo card value when an active combo is displayed: "×3" etc. The
         multiplication sign is the conventional form for combo notation in
         most locales; translators may swap it for an "x" letter if their
         convention differs. -->
    <string name="combo_value_format">×%1$d</string>

    <!-- v0.1.7 / v0.1.11: Interactive 5-step tutorial. Auto-runs on
         first launch and is re-openable from the menu. Each instruction
         sits on a card at the bottom of the screen above a dimmed
         background, with a Got it CTA and a Skip Tutorial text button.
         The Merge and Frame steps auto-advance when the user performs
         the scripted action; the combined Hazard step auto-advances
         when the player consumes the demo shield to clear a hazard;
         the Leaderboard step advances on the Leaderboard-button tap;
         the Username step advances on a successful name save. v0.1.11
         merged the former separate Hazard (intro) and Shield (use)
         steps into one combined step with two internal sub-phases. -->
    <string name="btn_tutorial">How to play</string>
    <string name="tutorial_step_counter">%1$d / %2$d</string>
    <string name="tutorial_cta_got_it">Got it</string>
    <string name="tutorial_cta_skip">Skip Tutorial</string>
    <string name="tutorial_step_merge_instruction">Drag one tile onto the matching tile to merge them.</string>
    <string name="tutorial_step_frame_instruction">Merge these tiles to unlock new frame cells.</string>
    <!-- v0.1.11: combined Hazard step. Sub-phase 0 introduces the
         locked hazard tiles; sub-phase 1 prompts the player to use
         the shield to clear one. Replaces the former
         tutorial_step_hazard_instruction + tutorial_step_shield_instruction
         pair. -->
    <string name="tutorial_step_hazards_and_shield_initial">These locked tiles are dangerous. Tap to learn how to clear them.</string>
    <string name="tutorial_step_hazards_and_shield_action">Use your shield to clear a hazard.</string>
    <string name="tutorial_step_shield_subhint">Tap the shield card to watch a video and earn 3 more shields.</string>
    <string name="tutorial_step_leaderboard_instruction">Your high scores are submitted to the global leaderboard automatically. Open it from the menu to see how you rank.</string>
    <string name="tutorial_hint_drag_to_merge">Try dragging the tiles together…</string>

    <!-- v0.1.8 hotfix: success-beat copy shown when an auto-advanced
         tutorial step (Merge, Frame, Shield) detects the user has
         completed the scripted action. The overlay swaps the
         instruction line for one of these and a checkmark glyph,
         then waits ~2s before advancing so the user has a moment
         to register that their action worked. -->
    <string name="tutorial_success_merge">Nice merge!</string>
    <string name="tutorial_success_frame">Frame opened!</string>
    <string name="tutorial_success_shield">Hazard cleared!</string>

    <!-- v0.2.0: Username system. Step 6 of the tutorial spotlights the
         player's own row in the global leaderboard and prompts them to
         pick a name, replacing the auto-assigned "#NNNNNN" identifier.
         Players can later tap their own row to change their name; a
         30-day cooldown applies between changes. -->
    <string name="tutorial_step_leaderboard_instruction_v2">Tap the Leaderboard button to see global rankings.</string>
    <string name="tutorial_step_username_instruction">Tap your row to pick a name.</string>
    <string name="username_dialog_title_first">Pick your name</string>
    <string name="username_dialog_title_change">Change your name</string>
    <string name="username_input_hint">Name</string>
    <string name="username_too_short">At least 2 characters</string>
    <string name="username_too_long">Max 20 characters</string>
    <string name="username_checking">Checking…</string>
    <string name="username_available">Available</string>
    <string name="username_taken">Already taken</string>
    <string name="username_network_error">Connection error</string>
    <string name="username_save">Save</string>
    <string name="username_cancel">Cancel</string>
    <string name="username_cooldown">You can change your name in %d days</string>
    <string name="username_change_failed">Save failed</string>
    <string name="username_change_saved">Name saved</string>

    <!-- v0.1.11: in-app update indicator strings. Used as
         contentDescription on the small badge next to the LAST TILE
         wordmark when Google Play surfaces a newer version through
         the FLEXIBLE in-app update API. -->
    <string name="update_available">Update available — tap to install</string>
    <string name="update_ready_to_install">Update downloaded — tap to install now</string>
</resources>
