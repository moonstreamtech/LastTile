// DEPLOY MANUALLY via Firebase Console > Firestore > Rules.
// Order: 1) Push APK to Play internal testing, 2) Verify on device,
// 3) Then Publish these rules. Roll back to permissive in 1 min if broken.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — readable by any authenticated user (leaderboard)
    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.userId == userId
                    && request.resource.data.bestScore is int
                    && request.resource.data.bestScore >= 0
                    && request.resource.data.displayName is string
                    && request.resource.data.numericId is string
                    && request.resource.data.numericId.matches('^#[0-9]{6}$');

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.userId == userId
                    && request.resource.data.bestScore is int
                    && request.resource.data.bestScore >= resource.data.bestScore
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() >= 2
                    && request.resource.data.displayName.size() <= 20
                    && request.resource.data.numericId == resource.data.numericId;

      allow delete: if false;
    }

    // Username reservations — readable by all auth, writable by owner
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Numeric ID reservations — read all auth, no client modification after create
    match /numericIds/{nnn} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
